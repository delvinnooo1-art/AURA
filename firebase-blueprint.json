{
  "entities": {
    "Quiz": {
      "title": "Quiz",
      "description": "Quiz configuration and questions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["quiz", "plastin"] },
        "token": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "durationMode": { "type": "string", "enum": ["fixed", "unlimited"] },
        "timeLimit": { "type": "number" },
        "uiMode": { "type": "string", "enum": ["laptop", "mobile", "adaptive"] },
        "scoringSystem": { "type": "string", "enum": ["point", "score", "weighted"] },
        "isLiveMode": { "type": "boolean" },
        "sessionMode": { "type": "string", "enum": ["practice", "live", "exam"] },
        "startMethod": { "type": "string", "enum": ["manual", "scheduled", "auto"] },
        "playerLimit": { "type": "number" },
        "lobbyRules": { "type": "object" },
        "enableSheetsExport": { "type": "boolean" },
        "deadlines": { "type": "object" },
        "questions": { "type": "array" },
        "plastin": { "type": "object" },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["id", "token", "title", "type"]
    },
    "Attempt": {
      "title": "Attempt",
      "description": "A user's quiz submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "quizTitle": { "type": "string" },
        "tokenUsed": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "maxScore": { "type": "number" },
        "scoringType": { "type": "string" },
        "answers": { "type": "object" },
        "timeTaken": { "type": "number" },
        "difficultyMetrics": { "type": "object" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["quizId", "userName", "score"]
    },
    "Lobby": {
      "title": "Lobby",
      "description": "Live session state",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["waiting", "started", "finished"] },
        "currentQuestionIndex": { "type": "number" },
        "players": { "type": "object" },
        "startTime": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Master quiz definitions"
    },
    "/submissions/{submissionId}": {
      "schema": "Attempt",
      "description": "User submissions and results"
    },
    "/lobbies/{token}": {
      "schema": "Lobby",
      "description": "Real-time lobby states"
    }
  }
}
