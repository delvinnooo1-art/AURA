rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && (request.auth.token.email == 'delvinnooo1@gmail.com' && request.auth.token.email_verified == true); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // --- Validations ---
    function isValidQuiz(data) {
      return data.id is string && data.token is string && data.title is string && data.type in ['quiz', 'plastin'];
    }

    function isValidSubmission(data) {
      return data.quizId is string && data.userName is string && data.score is number;
    }

    // --- Collections ---
    
    // Quizzes: Creators can create/update their own. Everyone can read to join.
    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if isSignedIn(); // Add ownership check in app logic, but let's be loose for now to allow local storage sync
      allow update, delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    // Submissions: Participants can create. Admins and Quiz Authors can read.
    match /submissions/{submissionId} {
      allow create: if true; // Allow anonymous submissions if app supports it
      allow read, list: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/quizzes/$(resource.data.quizId)).data.authorId == request.auth.uid);
      
      // Allow user to see their own if they were signed in
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Lobbies: Sync state for live sessions.
    match /lobbies/{token} {
      allow read, write: if true; // Public access for the sync token
    }
  }
}
