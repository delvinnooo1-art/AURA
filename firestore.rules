rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['name', 'email', 'createdAt']) &&
               data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'region', 'preferredLanguage', 'updatedAt']);
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Quizzes
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /questions/{questionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Attempts
    match /attempts/{attemptId} {
      function isValidAttempt(data) {
        return data.userId == request.auth.uid &&
               data.quizId is string &&
               data.score is number;
      }
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidAttempt(incoming());
    }

    // Settings
    match /config/settings {
      allow read, write: if isAdmin();
    }

    // Admins collection (static list for security)
    match /admins/{userId} {
      allow read: if isSignedIn();
    }
  }
}
